{
  "$ref": "#/definitions/blog",
  "definitions": {
    "blog": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "maxLength": 100,
          "errorMessage": {
            "maxLength": "العنوان يجب أن يكون أقل من 100 حرف"
          }
        },
        "description": {
          "type": "string",
          "maxLength": 200,
          "errorMessage": {
            "maxLength": "الوصف يجب أن يكون أقل من 200 حرف"
          }
        },
        "date": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "updatedDate": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "image": {
          "type": "object",
          "properties": {
            "src": {
              "type": "string"
            },
            "alt": {
              "type": "string",
              "default": "صورة المقال"
            },
            "width": {
              "type": "number"
            },
            "height": {
              "type": "number"
            }
          },
          "required": [
            "src"
          ],
          "additionalProperties": false
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "category": {
          "type": "string",
          "enum": [
            "الذكاء الاصطناعي",
            "التعلم العميق",
            "معالجة اللغات الطبيعية",
            "الرؤية الحاسوبية",
            "الشبكات العصبية",
            "Transformers",
            "ChatGPT",
            "Python",
            "أدوات وتقنيات",
            "مشاريع عملية"
          ],
          "default": "الذكاء الاصطناعي"
        },
        "readingTime": {
          "type": "number",
          "minimum": 1
        },
        "featured": {
          "type": "boolean",
          "default": false
        },
        "draft": {
          "type": "boolean",
          "default": false
        }
      },
      "required": [
        "title",
        "description",
        "date"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}