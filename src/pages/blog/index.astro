---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const blogPosts = await getCollection('blog');

// Filter out drafts and sort by date
const publishedPosts = blogPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="المدونة | محمد لحلح - مقالات الذكاء الاصطناعي" description="مقالات متعمقة حول الذكاء الاصطناعي، التعلم العميق، والشبكات العصبية">
  <main class="min-h-screen bg-[var(--bg-primary)] transition-colors duration-300">
    <!-- Header -->
    <section class="relative pt-32 pb-16 px-6 border-b border-[var(--border-subtle)]">
      <div class="max-w-6xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[var(--accent-purple)]/10 text-[var(--accent-purple)] font-bold text-sm mb-6 border border-[var(--accent-purple)]/20">
          📝 المدونة التقنية
        </div>
        <h1 class="text-4xl md:text-6xl font-black mb-6 hero-gradient leading-[1.1] tracking-tighter">
          مقالات في الذكاء الاصطناعي
        </h1>
        <p class="text-lg md:text-xl text-[var(--text-secondary)] max-w-3xl mx-auto leading-relaxed font-medium">
          شروحات متعمقة، تحليلات تقنية، ورؤى مستقبلية حول عالم AI
        </p>
      </div>
    </section>

    <!-- Blog Posts Grid -->
    <section class="py-16 px-6">
      <div class="max-w-6xl mx-auto">
        {publishedPosts.length === 0 ? (
          <div class="text-center py-20">
            <p class="text-[var(--text-secondary)] text-lg">لا توجد مقالات منشورة بعد</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {publishedPosts.map((post) => (
              <article class="glass-card rounded-2xl overflow-hidden group hover:scale-[1.02] transition-all duration-300">
                <!-- Featured Image -->
                {post.data.image && (
                  <div class="relative h-48 overflow-hidden">
                    <img 
                      src={post.data.image.src} 
                      alt={post.data.image.alt}
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                      loading="lazy"
                    />
                    {post.data.featured && (
                      <div class="absolute top-4 right-4 px-3 py-1 rounded-full bg-purple-600 text-white text-xs font-bold">
                        مميز
                      </div>
                    )}
                  </div>
                )}

                <!-- Content -->
                <div class="p-6">
                  <!-- Category -->
                  <div class="inline-block px-3 py-1 rounded-full bg-[var(--accent-purple)]/10 text-[var(--accent-purple)] text-[10px] font-bold mb-4 border border-[var(--accent-purple)]/20">
                    {post.data.category}
                  </div>

                  <!-- Title -->
                  <h2 class="text-xl font-black mb-3 text-[var(--text-primary)] leading-tight group-hover:text-[var(--accent-purple)] transition-colors">
                    <a href={`/blog/${post.slug}`} class="hover:underline">
                      {post.data.title}
                    </a>
                  </h2>

                  <!-- Description -->
                  <p class="text-[var(--text-secondary)] text-sm mb-4 line-clamp-3">
                    {post.data.description}
                  </p>

                  <!-- Meta -->
                  <div class="flex items-center justify-between text-xs text-[var(--text-muted)]">
                    <time datetime={post.data.date.toISOString()}>
                      {new Intl.DateTimeFormat('ar', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric',
                      }).format(post.data.date)}
                    </time>
                    {post.data.readingTime && (
                      <span>{post.data.readingTime} دقيقة</span>
                    )}
                  </div>

                  <!-- Tags -->
                  {post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2 mt-4">
                      {post.data.tags.slice(0, 3).map((tag) => (
                        <span class="text-[10px] px-2 py-1 rounded-full bg-[var(--bg-tertiary)] border border-[var(--border-subtle)] text-[var(--text-muted)]">
                          #{tag}
                        </span>
                      ))}
                    </div>
                  )}

                  <!-- Read More -->
                  <a 
                    href={`/blog/${post.slug}`}
                    class="inline-flex items-center gap-2 mt-6 text-[var(--accent-purple)] font-bold text-sm hover:gap-3 transition-all"
                  >
                    اقرأ المزيد
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M19 12H5M12 19l-7-7 7-7"/>
                    </svg>
                  </a>
                </div>
              </article>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>
</BaseLayout>
